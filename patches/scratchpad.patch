+void
+spawnscratch(const Arg *arg)
+{
+	if (fork() == 0) {
+		dup2(STDERR_FILENO, STDOUT_FILENO);
+		setsid();
+		execvp(((char **)arg->v)[1], (char **)arg->v + 1);
+		die("dwl: execvp %s failed:", ((char **)arg->v)[1]);
+	}
+}
