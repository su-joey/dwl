+void
+focusortogglematchingscratch(const Arg *arg)
+{
+	Client *c;
+	int found = 0, hide = 0;
+	char scratchkey = ((char **)arg->v)[0][0];
+
+	wl_list_for_each(c, &clients, link) {
+		if (!c->scratchkey)
+			continue;
+		if (c->scratchkey == scratchkey) {
+			if (VISIBLEON(c, selmon)) {
+				if (found) {
+					if (hide) {
+						c->tags = 0;
+						focusclient(focustop(selmon), 1);
+					}
+					continue;
+				}
+				if (focustop(selmon) == c) {
+					c->tags = 0;
+					focusclient(focustop(selmon), 1);
+					hide = 1;
+				} else {
+					focusclient(c, 1);
+				}
+			} else {
+				c->tags = selmon->tagset[selmon->seltags];
+				focusclient(c, 1);
+			}
+			found = 1;
+			continue;
+		}
+		if (VISIBLEON(c, selmon))
+			c->tags = 0;
+	}
+
+	if (found)
+		arrange(selmon);
+	else
+		spawnscratch(arg);
+}
+
+void
